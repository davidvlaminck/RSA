FACTORY_DEF * TeeFactory   FACTORY_NAME "setHyperlink Input Input Collector"   INPUT FEATURE_TYPE JSONFeature_JSON_1   OUTPUT FEATURE_TYPE setHyperlink_Input
MACRO setHyperlink_WORKSPACE_NAME setHyperlink
MACRO $(setHyperlink_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(setHyperlink_WORKSPACE_NAME)_XFORMER_NAME setHyperlink
MACRO $(setHyperlink_WORKSPACE_NAME)___COMPOUND_PARAMETERS 
MACRO $(setHyperlink_WORKSPACE_NAME)_UUID <at>Value<openparen>uuid<closeparen>
MACRO $(setHyperlink_WORKSPACE_NAME)_BESTEKKEN <at>Value<openparen>bestekken<closeparen>
MACRO $(setHyperlink_WORKSPACE_NAME)_NAAM <at>Value<openparen>naam<closeparen>
MACRO $(setHyperlink_WORKSPACE_NAME)_NAAMPAD <at>Value<openparen>naampad<closeparen>
MACRO $(setHyperlink_WORKSPACE_NAME)_TOESTAND <at>Value<openparen>toestand<closeparen>
MACRO $(setHyperlink_WORKSPACE_NAME)_SUB_DOC_NAME setHyperlink
MACRO $(setHyperlink_WORKSPACE_NAME)_SUB_DOC_NAME setHyperlink
DEFAULT_MACRO setHyperlink_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(setHyperlink_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(setHyperlink_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(setHyperlink_WORKSPACE_NAME)_Input1769700620 Input Splitter"   INPUT FEATURE_TYPE "$(setHyperlink_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(setHyperlink_WORKSPACE_NAME)_Input" "@EvaluateExpression(ATTR_CREATE_EXPR_PROPAGATE_MISSING_FDIV_TYPED,uuid,$($(setHyperlink_WORKSPACE_NAME)_UUID),UTF8,bestekken,$($(setHyperlink_WORKSPACE_NAME)_BESTEKKEN),UTF8,naam,$($(setHyperlink_WORKSPACE_NAME)_NAAM),UTF8,naampad,$($(setHyperlink_WORKSPACE_NAME)_NAAMPAD),UTF8,toestand,$($(setHyperlink_WORKSPACE_NAME)_TOESTAND),UTF8, FEATURE_TYPE)"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(setHyperlink_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(setHyperlink_WORKSPACE_NAME)_Input"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "uuid.hyperlink" "SET_TO" "https:<solidus><solidus>apps.mow.vlaanderen.be<solidus>eminfra<solidus>assets<solidus><at>Value<openparen>uuid<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(setHyperlink_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(setHyperlink_WORKSPACE_NAME)_Output1769700620 Output Collector"   INPUT FEATURE_TYPE "$(setHyperlink_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(setHyperlink_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(setHyperlink_WORKSPACE_NAME))}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "setHyperlink Output Output Renamer/Nuker"   INPUT FEATURE_TYPE setHyperlink_Output   OUTPUT FEATURE_TYPE setHyperlink_Output
